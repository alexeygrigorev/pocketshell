#!/bin/sh
set -eu

# Issue #231 (D22 hard-cut): the bootstrapper now probes/installs the single
# unified `pocketshell` CLI instead of the legacy `tmuxctl` + `quse` binaries.
# This bootstrap fixture only needs to prove `pocketshell` is on PATH, runs
# `--version` cleanly, and that the jobs-daemon ExecStart target
# (`pocketshell jobs daemon`) resolves.
version_file="${POCKETSHELL_BOOTSTRAP_VERSION_FILE:-/tmp/pocketshell-bootstrap-pocketshell-version}"
latest_version_file="${POCKETSHELL_BOOTSTRAP_LATEST_VERSION_FILE:-/tmp/pocketshell-bootstrap-latest-version}"
fixture_version="${POCKETSHELL_BOOTSTRAP_LATEST_VERSION:-}"
if [ -z "$fixture_version" ] && [ -r "$latest_version_file" ]; then
  fixture_version="$(cat "$latest_version_file")"
fi
fixture_version="${fixture_version:-0.3.8}"
if [ -r "$version_file" ]; then
  fixture_version="$(cat "$version_file")"
fi

if [ "${1:-}" = "--version" ]; then
  printf 'pocketshell bootstrap fixture %s\n' "$fixture_version"
  exit 0
fi

if [ "${1:-}" = "jobs" ] && [ "${2:-}" = "daemon" ]; then
  printf 'pocketshell jobs daemon fixture\n'
  exit 0
fi

if [ "${1:-}" = "jobs" ] && [ "${2:-}" = "list" ]; then
  printf 'ID  ENABLED  SESSION  EVERY  DELAY  SOURCE  NEXT RUN  DETAIL\n'
  exit 0
fi

printf 'pocketshell bootstrap fixture supports --version, jobs daemon, and jobs list\n' >&2
exit 64
