#!/bin/sh
set -eu

# Issue #231 (D22 hard-cut): the app's unified `pocketshell` daemon unit is
# `pocketshell-jobs.service` (see HostBootstrapper). This fixture answers the
# agents-image daemon status probes the contract test exercises.
if [ "${1:-}" = "--user" ] && [ "${2:-}" = "is-active" ] && [ "${3:-}" = "pocketshell-jobs.service" ]; then
  printf 'active\n'
  exit 0
fi

if [ "${1:-}" = "--user" ] && [ "${2:-}" = "is-enabled" ] && [ "${3:-}" = "pocketshell-jobs.service" ]; then
  printf 'enabled\n'
  exit 0
fi

printf 'systemctl fixture supports pocketshell-jobs.service status only\n' >&2
exit 3
