#!/bin/sh
set -eu

case "${1:-}" in
  --version)
    printf 'heru bootstrap fixture 0.0.0\n'
    ;;
  usage)
    if [ "${2:-}" = "--json" ]; then
      printf '[]\n'
      exit 0
    fi
    printf 'heru bootstrap fixture supports --version and usage --json\n' >&2
    exit 64
    ;;
  *)
    printf 'heru bootstrap fixture supports --version and usage --json\n' >&2
    exit 64
    ;;
esac
