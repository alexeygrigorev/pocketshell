#!/bin/sh
set -eu

# Deterministic fixture for the unified `pocketshell` CLI.
#
# Issue #231 swapped the Android app from the legacy `quse` / `tmuxctl`
# probes to the unified `pocketshell usage|sessions|jobs ...` CLI (D22
# hard-cut). On a real host `pocketshell` is a thin wrapper that proxies
# its output byte-for-byte from the underlying `quse` / `tmuxctl`
# binaries (see tools/pocketshell/src/pocketshell/{usage,sessions,jobs}.py),
# so this fixture reuses the same canned payloads the app's parsers were
# written against:
#   - `pocketshell usage --json`            -> PocketshellUsageJsonParser
#   - `pocketshell sessions list [--by ..]` -> HostTmuxSessionListParser
#   - `pocketshell jobs list [--session N]` -> RecurringJobsParser
#   - `pocketshell agent-log --json ...`    -> AgentConversationRepository

fixture_dir="${POCKETSHELL_AGENT_FIXTURE_DIR:-/opt/pocketshell-agent-fixtures}"
version_file="${POCKETSHELL_AGENT_FIXTURE_VERSION_FILE:-/opt/pocketshell-agent-fixture-version}"

fixture_version() {
  if [ -n "${POCKETSHELL_AGENT_FIXTURE_VERSION:-}" ]; then
    printf '%s\n' "$POCKETSHELL_AGENT_FIXTURE_VERSION"
    return 0
  fi
  if [ -r "$version_file" ]; then
    cat "$version_file"
    return 0
  fi
  if [ -r "${POCKETSHELL_PROJECT_ROOT:-.}/app/build.gradle.kts" ]; then
    parsed_version="$(
      sed -n 's/^[[:space:]]*versionName[[:space:]]*=[[:space:]]*"\([^"]*\)".*$/\1/p' \
        "${POCKETSHELL_PROJECT_ROOT:-.}/app/build.gradle.kts" | head -n 1
    )"
    if [ -n "$parsed_version" ]; then
      printf '%s\n' "$parsed_version"
      return 0
    fi
  fi
  printf '0.0.0\n'
}

json_escape_awk='
function esc(s) {
  gsub(/\\/, "\\\\", s)
  gsub(/"/, "\\\"", s)
  return s
}
{
  lines[++count] = $0
}
END {
  printf "{\"count\":%d,\"engine\":\"%s\",\"lines\":[", count, engine
  for (i = 1; i <= count; i++) {
    if (i > 1) printf ","
    printf "\"%s\"", esc(lines[i])
  }
  printf "],\"path\":\"%s\",\"session\":\"%s\"}\n", esc(path), esc(session)
}
'

case "${1:-}" in
  --version)
    printf 'pocketshell fixture %s\n' "$(fixture_version)"
    exit 0
    ;;
  agent)
    # Issue #703: the app now launches agents via the short server-side
    # wrapper `pocketshell agent <kind> --dir <dir> [--no-skip-permissions]
    # [--config-dir <dir>]` instead of a giant inline env-strip line. This
    # fixture mirrors the real wrapper's observable behaviour: parse the
    # short argv, cd into --dir, then exec the (fake) agent so the
    # AgentLaunchCommandDockerTest sees the agent's ready output land in the
    # pane — proving the wrapper exec'd the agent, not just that text was
    # typed. The real wrapper additionally merges .env/.envrc, strips the
    # provider env for opencode, and suppresses first-run prompts; the fake
    # agents have no such prompts so nothing extra is needed here.
    shift
    agent_kind="${1:-}"
    shift || true
    agent_dir=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --dir)
          agent_dir="${2:-}"
          shift 2
          ;;
        --skip-permissions|--no-skip-permissions)
          shift
          ;;
        --config-dir)
          shift 2
          ;;
        *)
          shift
          ;;
      esac
    done
    if [ -n "$agent_dir" ]; then
      cd "$agent_dir" 2>/dev/null || true
    fi
    case "$agent_kind" in
      codex|claude|opencode)
        exec "$agent_kind"
        ;;
      *)
        printf 'pocketshell agent fixture supports: codex|claude|opencode\n' >&2
        exit 64
        ;;
    esac
    ;;
  agents)
    # Epic #821 A2-infra (issue #827): the unified CLI grew `pocketshell
    # agents kind`, the seam over the `agents.kind_for_panes` daemon RPC. The
    # client pipes a pane list as `{"panes":[{"pane_id","pane_pid"}, ...]}` JSON
    # on stdin (and/or `--pane PANE_ID=PANE_PID`) and parses back
    # `{"results":[{"pane_id","agent_kind","scope","evidence_pid"?}]}`.
    #
    # This Docker container has no real cgroup-v2 scope tree, so the fixture
    # can't run the live classifier. Instead it answers DETERMINISTICALLY,
    # keyed off the pane_pid the test supplies, so a connected test can assert a
    # foreign session's guessed kind without seeding a cgroup tree:
    #   pid 1000-1999 -> claude (scope tmuxctl-claude-main.scope)
    #   pid 2000-2999 -> codex  (scope tmuxctl-codex.scope)
    #   pid 3000-3999 -> opencode (scope tmuxctl-opencode-lab.scope)
    #   pid 4000-4999 -> none   (scope tmuxctl-shell.scope; readable, no agent)
    #   missing / non-integer / any other pid -> unknown (scope null)
    # These ranges line up with the seeded fixture sessions claude-main / codex
    # / opencode-lab (see pocketshell-sessions-list.txt) so the guess matches
    # the session the test joins.
    shift
    if [ "${1:-}" != "kind" ]; then
      printf 'pocketshell agents fixture supports: kind\n' >&2
      exit 64
    fi
    shift

    # Collect panes from --pane PANE_ID=PANE_PID options.
    pane_specs=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --pane)
          pane_specs="${pane_specs}${2:-}
"
          shift 2
          ;;
        --proc-root|--cgroup-mount)
          shift 2
          ;;
        *)
          shift
          ;;
      esac
    done

    # Read stdin JSON panes when stdin is not a terminal. Extract pane_id /
    # pane_pid pairs without a JSON parser (busybox has no jq): pull every
    # "pane_id":... and "pane_pid":... token in document order. pane_pid is
    # numeric in the RPC shape; a missing pid yields an empty field -> unknown.
    if [ ! -t 0 ]; then
      stdin_json="$(cat)"
    else
      stdin_json=""
    fi

    printf '%s' "$stdin_json" | tr ',' '\n' | awk -v specs="$pane_specs" '
      function classify(pid,   n) {
        if (pid !~ /^[0-9]+$/) return "unknown\tnull"
        n = pid + 0
        if (n >= 1000 && n < 2000) return "claude\ttmuxctl-claude-main.scope"
        if (n >= 2000 && n < 3000) return "codex\ttmuxctl-codex.scope"
        if (n >= 3000 && n < 4000) return "opencode\ttmuxctl-opencode-lab.scope"
        if (n >= 4000 && n < 5000) return "none\ttmuxctl-shell.scope"
        return "unknown\tnull"
      }
      function esc(s) { gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); return s }
      function emit(pid, pane_id,   c, kind, scope, parts) {
        c = classify(pid)
        split(c, parts, "\t")
        kind = parts[1]; scope = parts[2]
        if (n++ > 0) printf ","
        if (scope == "null") sval = "null"; else sval = "\"" esc(scope) "\""
        printf "{\"pane_id\":\"%s\",\"agent_kind\":\"%s\",\"scope\":%s}", esc(pane_id), kind, sval
      }
      BEGIN {
        printf "{\"results\":["
        # --pane PANE_ID=PANE_PID specs first.
        m = split(specs, lines, "\n")
        for (i = 1; i <= m; i++) {
          if (lines[i] == "") continue
          eq = index(lines[i], "=")
          if (eq == 0) continue
          pid_id = substr(lines[i], 1, eq - 1)
          pid_pid = substr(lines[i], eq + 1)
          emit(pid_pid, pid_id)
        }
      }
      # stdin JSON tokens, one comma-split fragment per line.
      /"pane_id"/ {
        if (match($0, /"pane_id"[ \t]*:[ \t]*"[^"]*"/)) {
          s = substr($0, RSTART, RLENGTH)
          sub(/^"pane_id"[ \t]*:[ \t]*"/, "", s); sub(/"$/, "", s)
          pending_id = s; have_id = 1
        }
      }
      /"pane_pid"/ {
        if (match($0, /"pane_pid"[ \t]*:[ \t]*[0-9]+/)) {
          s = substr($0, RSTART, RLENGTH)
          sub(/^"pane_pid"[ \t]*:[ \t]*/, "", s)
          pending_pid = s; have_pid = 1
        } else {
          pending_pid = ""; have_pid = 1
        }
      }
      # A pane object closes either at its `}` or when the next pane_id starts;
      # flush when we have both fields collected for the current object.
      (have_id && have_pid) {
        emit(pending_pid, pending_id)
        have_id = 0; have_pid = 0; pending_id = ""; pending_pid = ""
      }
      END { printf "]}\n" }
    '
    exit 0
    ;;
  profiles)
    # Issue #718 / #732: the Android picker fetches host-defined agent
    # profiles with `pocketshell profiles list [--engine <e>] --json`, so a
    # real discovery journey can list + select a host profile instead of
    # false-greening on ToolUnavailable. This branch mirrors the real CLI's
    # conservative auto-discovery (profiles.py): the seeded ~/.claude default
    # dir → the "Claude" default profile (config_dir=null), and the sibling
    # ~/.zlaude dir → the non-default "Claude (Z.AI)" profile pointing at its
    # absolute config_dir. Both dirs are seeded with a real marker file in
    # the entrypoint, so they reflect genuine on-host discovery, not a canned
    # blob. Output shape matches SshProfilesGateway.parseProfiles:
    #   {"profiles":[{"name","engine","config_dir","default"}, …]}.
    shift
    if [ "${1:-}" != "list" ]; then
      printf 'pocketshell profiles fixture supports: list [--engine claude|codex] [--json]\n' >&2
      exit 64
    fi
    shift
    profiles_engine=""
    profiles_json=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --engine)
          profiles_engine="${2:-}"
          shift 2
          ;;
        --json)
          profiles_json=1
          shift
          ;;
        *)
          printf 'pocketshell profiles fixture: unknown argument: %s\n' "$1" >&2
          exit 64
          ;;
      esac
    done

    home_dir="${HOME:-/home/testuser}"

    # Build the discovered claude profile rows from the seeded dirs. A dir
    # only counts when it carries a real claude marker file, exactly like
    # profiles.py's _has_marker (conservative — no phantom profiles).
    has_claude_marker() {
      [ -d "$1" ] && { [ -f "$1/.claude.json" ] || [ -f "$1/settings.json" ]; }
    }

    # name<TAB>engine<TAB>config_dir(empty=default)<TAB>default(true/false)
    rows=""
    if has_claude_marker "${home_dir}/.claude"; then
      rows="${rows}Claude	claude		true
"
    fi
    if has_claude_marker "${home_dir}/.zlaude"; then
      rows="${rows}Claude (Z.AI)	claude	${home_dir}/.zlaude	false
"
    fi
    # codex has no seeded profile dir in this fixture, so nothing to add.

    if [ -n "$profiles_engine" ]; then
      rows="$(printf '%s' "$rows" | awk -F '\t' -v e="$profiles_engine" 'NF && $2==e')"
    else
      rows="$(printf '%s' "$rows" | awk -F '\t' 'NF')"
    fi

    if [ "$profiles_json" -eq 1 ]; then
      printf '%s\n' "$rows" | awk -F '\t' '
        function esc(s) { gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); return s }
        BEGIN { printf "{\n  \"profiles\": [" }
        NF {
          if (n++ > 0) printf ","
          cd = ($3 == "" ? "null" : "\"" esc($3) "\"")
          printf "\n    {\"name\": \"%s\", \"engine\": \"%s\", \"config_dir\": %s, \"default\": %s}", esc($1), esc($2), cd, $4
        }
        END { if (n > 0) printf "\n  "; printf "]\n}\n" }
      '
      exit 0
    fi

    # YAML fallback (the real CLI default; the client always passes --json).
    printf 'profiles:\n'
    printf '%s\n' "$rows" | awk -F '\t' '
      NF {
        printf "  - name: %s\n", $1
        printf "    engine: %s\n", $2
        if ($3 == "") printf "    config_dir: null\n"; else printf "    config_dir: %s\n", $3
        printf "    default: %s\n", $4
      }
    '
    exit 0
    ;;
  usage)
    shift
    if [ "${1:-}" = "--json" ]; then
      cat "${fixture_dir}/pocketshell-usage.ndjson"
      exit 0
    fi
    printf 'pocketshell usage fixture supports: --json\n' >&2
    exit 64
    ;;
  sessions)
    shift
    if [ "${1:-}" = "list" ]; then
      # The app emits `pocketshell sessions list --by activity`; the
      # fixture ignores the sort flag and returns the canonical listing
      # so the trailing-timestamp parser sees a stable shape.
      cat "${fixture_dir}/pocketshell-sessions-list.txt"
      exit 0
    fi
    printf 'pocketshell sessions fixture supports: list [--by created|activity]\n' >&2
    exit 64
    ;;
  jobs)
    shift
    case "${1:-}" in
      list)
        cat "${fixture_dir}/pocketshell-jobs-list.txt"
        exit 0
        ;;
      add)
        printf 'Created job 4\n'
        exit 0
        ;;
      edit)
        printf 'Updated job %s\n' "${2:-}"
        exit 0
        ;;
      remove)
        printf 'Removed job %s\n' "${2:-}"
        exit 0
        ;;
    esac
    printf 'pocketshell jobs fixture supports: list/add/edit/remove\n' >&2
    exit 64
    ;;
  agent-log)
    shift
    engine=""
    session=""
    tail_count=""
    json_output=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --engine|-e)
          engine="${2:-}"
          shift 2
          ;;
        --session|-s)
          session="${2:-}"
          shift 2
          ;;
        --tail|-n)
          tail_count="${2:-}"
          shift 2
          ;;
        --json)
          json_output=1
          shift
          ;;
        --cwd)
          shift 2
          ;;
        *)
          printf 'unknown agent-log argument: %s\n' "$1" >&2
          exit 64
          ;;
      esac
    done
    [ -n "$engine" ] && [ -n "$session" ] || {
      printf 'pocketshell agent-log fixture requires --engine and --session\n' >&2
      exit 64
    }
    filename="${session%.jsonl}.jsonl"
    case "$engine" in
      codex)
        path="$(find "$HOME/.codex/sessions" -type f -name "$filename" -print 2>/dev/null | head -n 1)"
        ;;
      claude)
        path="$(find "$HOME/.claude/projects" -type f -name "$filename" -print 2>/dev/null | head -n 1)"
        ;;
      opencode)
        path="$HOME/.local/share/opencode/$filename"
        [ -f "$path" ] || path=""
        ;;
      *)
        printf 'unsupported fixture agent-log engine: %s\n' "$engine" >&2
        exit 64
        ;;
    esac
    [ -n "$path" ] && [ -f "$path" ] || {
      printf 'no %s session log found for %s\n' "$engine" "$session" >&2
      exit 66
    }
    if [ -n "$tail_count" ]; then
      reader="tail -n $tail_count"
    else
      reader="cat"
    fi
    if [ "$json_output" -eq 1 ]; then
      # shellcheck disable=SC2086
      $reader "$path" | awk -v engine="$engine" -v session="${session%.jsonl}" -v path="$path" "$json_escape_awk"
    else
      # shellcheck disable=SC2086
      $reader "$path"
    fi
    exit 0
    ;;
esac

printf 'pocketshell fixture supports: usage --json, sessions list, jobs list/add/edit/remove, agent-log, profiles list, agents kind\n' >&2
exit 64
