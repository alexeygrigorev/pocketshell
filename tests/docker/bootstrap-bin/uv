#!/bin/sh
set -eu

if [ "${1:-}" = "tool" ] && [ "${2:-}" = "install" ]; then
  action="install"
  if [ "${3:-}" = "--upgrade" ]; then
    action="install --upgrade"
    package="${4:-}"
  else
    package="${3:-}"
  fi
  if [ -z "$package" ]; then
    printf 'uv bootstrap fixture supports: tool install [--upgrade] <package>\n' >&2
    exit 64
  fi
  target_dir="${HOME}/.local/bin"
  source_dir="${POCKETSHELL_BOOTSTRAP_BIN_DIR:-/opt/pocketshell-bootstrap-bin}"
  version_file="${POCKETSHELL_BOOTSTRAP_VERSION_FILE:-/tmp/pocketshell-bootstrap-pocketshell-version}"
  install -d "$target_dir"
  cp "${source_dir}/${package}" "${target_dir}/${package}"
  chmod +x "${target_dir}/${package}"
  if [ "$package" = "pocketshell" ]; then
    printf '0.3.7\n' > "$version_file"
  fi
  printf '%s fixture tool %s\n' "$action" "$package"
  exit 0
fi

if [ "${1:-}" = "tool" ] && [ "${2:-}" = "upgrade" ] && [ -n "${3:-}" ]; then
  package="$3"
  target_dir="${HOME}/.local/bin"
  source_dir="${POCKETSHELL_BOOTSTRAP_BIN_DIR:-/opt/pocketshell-bootstrap-bin}"
  version_file="${POCKETSHELL_BOOTSTRAP_VERSION_FILE:-/tmp/pocketshell-bootstrap-pocketshell-version}"
  if [ ! -x "${target_dir}/${package}" ]; then
    printf 'uv fixture cannot upgrade unmanaged tool: %s\n' "$package" >&2
    exit 2
  fi
  cp "${source_dir}/${package}" "${target_dir}/${package}"
  chmod +x "${target_dir}/${package}"
  if [ "$package" = "pocketshell" ]; then
    printf '0.3.7\n' > "$version_file"
  fi
  printf 'upgrade fixture tool %s\n' "$package"
  exit 0
fi

printf 'uv bootstrap fixture supports: tool install [--upgrade] <package> and managed tool upgrade <package>\n' >&2
exit 64
