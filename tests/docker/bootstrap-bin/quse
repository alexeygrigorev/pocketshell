#!/bin/sh
set -eu

case "${1:-}" in
  --version)
    printf 'quse bootstrap fixture 0.0.0\n'
    ;;
  --json)
    # Empty NDJSON output keeps the bootstrap fixture distinct from the
    # agents fixture: the bootstrap scenarios only need to prove that
    # `quse` is on PATH and runs cleanly with `--json`.
    exit 0
    ;;
  *)
    printf 'quse bootstrap fixture supports --version and --json\n' >&2
    exit 64
    ;;
esac
