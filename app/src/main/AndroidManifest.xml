<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Required for the Phase 0 proof-of-life screen to open an SSH
        connection to the configured host. Phase 1 will revisit this when
        the host management UI lands — for now this single permission
        covers the smoke test.

        INTERNET is also required by the voice prompt composer (issue #15)
        for the multipart upload to OpenAI's Whisper endpoint.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Issue #180: the prompt composer needs to know whether the device is
        online so it can skip the Whisper round-trip when there's no
        network and queue the audio for retry-on-foreground-resume
        instead of burning a 60s OkHttp call timeout. `ACCESS_NETWORK_STATE`
        is the lowest-privilege way to query `ConnectivityManager` —
        consistent with the project's no-background-work principle (D21),
        we do NOT take `CHANGE_NETWORK_STATE` or any background-execution
        permission, just the passive read.
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Issue #15: the prompt composer captures microphone audio for the
        Whisper transcription round-trip. `RECORD_AUDIO` is declared at
        manifest level (system-level gating) and additionally requested at
        runtime — see `PromptComposerSheet` for the runtime prompt flow
        via `rememberLauncherForActivityResult`.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!--
        Issue #129: live QR camera scanner. The user points the phone
        camera at a QR code rendered on their desktop to import a host
        config + SSH key without saving anything to disk. The runtime
        rationale is in `R.string.qr_scanner_camera_permission_rationale`
        and surfaced by `QrScannerScreen` before the system prompt fires.
        Declared optional so devices without a back camera can still
        install the app; the scanner screen routes to the file-picker
        fallback when the hardware is absent.
    -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Issue #203 expanded scope (round 3, foreground-service slice):
        the auto-forward feature carve-out (D21, see `docs/decisions.md`)
        allows a foreground service while ≥1 SSH tunnel is active so the
        device-side SSH transport survives backgrounding. PocketShell's
        usage doesn't fit any of the pre-defined service types
        (`dataSync`, `mediaPlayback`, `connectedDevice`, ...): we're
        holding a user-initiated network transport open without doing
        media playback or device-to-device communication, so we use
        the catch-all `specialUse` type with a `propertyName` value
        that documents the use case for store review.

        `FOREGROUND_SERVICE` is the basic permission required on all
        SDK levels; `FOREGROUND_SERVICE_SPECIAL_USE` is the
        per-type permission required on Android 14+ when the service
        declares `foregroundServiceType="specialUse"`.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!--
        Android 11+ package visibility: SpeechRecognizer availability checks
        query installed RecognitionService implementations. Without this
        targetSdk 35 builds can see `isRecognitionAvailable(...) == false`
        even when a system speech service is installed.
    -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PocketShell">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PocketShell">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Issue #129: deep-link `pocketshell://import?payload=...`
                URLs route directly to the host-import path. MainActivity
                inspects the launching intent in `onCreate` /
                `onNewIntent` and hands the `payload` query parameter to
                `HostListViewModel.importSharedHostPayload`. `BROWSABLE`
                is required so the link is followable from a browser /
                share sheet; `DEFAULT` makes the implicit-intent match
                succeed without an explicit component.

                The desktop emitter under `tools/qr-share/` can emit a
                single deep-link URL for the common case where a host
                config (no embedded key) fits inside the URL budget, so
                the user only ever sees one tap-to-import action.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="pocketshell" android:host="import" />
            </intent-filter>
        </activity>

        <activity
            android:name=".terminal.TerminalLabActivity"
            android:exported="false"
            android:theme="@style/Theme.PocketShell" />

        <!--
            Issue #138: Android share-target. PocketShell appears in the
            system share sheet for files (image / audio / video / text /
            generic) and short text payloads. The activity is launched
            with `singleTop` so a back-to-back share from the same
            source app re-uses the existing task instead of stacking
            multiple ShareActivity instances. `excludeFromRecents` keeps
            the share intent out of the recents stack — a share is a
            transactional surface, not something the user expects to
            resume from the launcher.
        -->
        <activity
            android:name=".share.ShareActivity"
            android:exported="true"
            android:label="@string/share_target_label"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:noHistory="false"
            android:theme="@style/Theme.PocketShell">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="text/*" />
                <data android:mimeType="application/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="text/*" />
                <data android:mimeType="application/*" />
            </intent-filter>
            <!--
                Generic catch-all so the activity still appears for
                MIME types the well-known wildcards above don't cover
                (e.g. an arbitrary `*/*` from a poorly-configured
                source app).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!--
            Issue #138 connected-emulator test: the share-target end-to-end
            test stages a temp file under the target app's cache and hands
            its URI to `ShareActivity`. The FileProvider is declared here
            (production manifest) because the FileProvider component must
            run in the same process as the file it serves, and the
            androidTest harness exercises the target app's process. The
            component is not exported, so production builds carry an
            inert FileProvider with no attack surface — it can only ever
            serve files under the `share-target-tests/` subdirectory of
            the app's cache, which production code never writes to.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.shareprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/share_target_test_provider_paths" />
        </provider>

        <!--
            Issue #181: AI Costs CSV export. The "Export as CSV" action
            on the AI Costs screen writes a timestamped file under
            `cacheDir/ai-costs-export/` and hands its content URI to
            `ACTION_SEND` so the user can drop it into email / GDrive /
            a finance app. The authority is `.fileprovider` (matching
            the broader Android convention) so the export code stays
            independent of the test-only `.shareprovider` above —
            keeping the two authorities separate means a future change
            to either one can't accidentally widen the other's surface.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/ai_costs_export_paths" />
        </provider>

        <receiver
            android:name=".systemsurfaces.ActiveSessionsWidgetProvider"
            android:exported="true"
            android:label="@string/widget_active_sessions_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/active_sessions_widget_info" />
        </receiver>

        <service
            android:name=".systemsurfaces.ForwardingTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_forwarding"
            android:label="@string/qs_forwarding_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name=".systemsurfaces.BootCompletedReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
            Issue #619: delete-intent target for usage warning notifications.
            A user swipe durably records the dismissed crossing so it does not
            re-fire on the next sync / cold launch. Not exported: the
            deleteIntent is fired by the system within this app only.
        -->
        <receiver
            android:name=".usage.UsageNotificationDismissReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.pocketshell.app.usage.action.USAGE_NOTIFICATION_DISMISSED" />
            </intent-filter>
        </receiver>

        <!--
            Issue #203 expanded scope (round 3): foreground service for
            the SSH port-forwarding feature. See
            `com.pocketshell.app.portfwd.service.ForwardingService` for
            the runtime behaviour and `docs/decisions.md` D21 for the
            background-work carve-out rationale.

            `foregroundServiceType="specialUse"` is required on Android
            14+ because PocketShell's use case (keep a user-initiated
            SSH transport alive while the app is backgrounded so port
            forwards survive) doesn't match any of the pre-defined
            types like `dataSync` (we're not syncing data on a schedule)
            or `connectedDevice` (we're not communicating with a
            companion device). The accompanying
            `FOREGROUND_SERVICE_SPECIAL_USE.subtype` property is
            informational metadata that helps Google Play reviewers
            understand the intent if/when the app ships to the store.

            `android:exported="false"` because the service is started
            from PocketShell's own code only — third-party apps must
            not be able to wake it.
        -->
        <service
            android:name=".portfwd.service.ForwardingService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps SSH port-forwarding tunnels alive while the app is backgrounded, scoped to hosts the user explicitly enabled auto-forward on." />
        </service>

        <!--
            Issue #690: Firebase Cloud Messaging receiver for usage-limit reset
            pushes. D21-safe: Google Play Services (NOT this app) holds the push
            connection, so there is no app-side background work — the OS wakes
            this service only when a push arrives. The service turns a
            `usage_reset` data message into a notification that deep-links to the
            Usage screen.

            Not exported: only the FCM library binds it (it enforces the
            `com.google.android.c2dm.permission.SEND` permission on the dispatch
            intent), so third-party apps cannot deliver fake pushes.
        -->
        <service
            android:name=".messaging.PocketShellMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
