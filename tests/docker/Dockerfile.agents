# Agent-capable local test image for PocketShell.
#
# This image is intentionally deterministic: it exposes the command names
# PocketShell probes without installing real provider CLIs or requiring API
# credentials. Use it for local emulator + Docker smoke tests only.
FROM alpine:latest

# Issue #1091: `nano` is the maintainer's real dogfood TUI (he was trapped in
# GNU nano, unable to save/exit from PocketShell). The connected nano save/exit
# journey (`TmuxKeyBarCtrlComboE2eTest`) opens a real nano buffer and drives
# `^O`/`^X` from the hotkeys panel, so the fixture must ship a real `nano`.
RUN apk add --no-cache openssh-server openssh-client tmux procps bash sqlite git nano \
    && ssh-keygen -A \
    && adduser -D -s /bin/sh testuser \
    && passwd -u testuser \
    && mkdir -p /home/testuser/.ssh \
    && chmod 700 /home/testuser/.ssh

COPY tests/docker/sshd_config /etc/ssh/sshd_config
COPY tests/docker/test_key.pub /home/testuser/.ssh/authorized_keys
# Issue #150: see Dockerfile.ssh — same rationale for the in-container
# compose healthcheck. The private key is a committed test fixture.
COPY tests/docker/test_key /root/test_key
COPY tests/docker/agent-bin/ /usr/local/bin/
# Issue #1302/#1208: the recovery-journey fixture scripts ship here too. They
# REUSE this `agents` service (host port 2222) — NO new service/port is needed:
# the composite recovery journey seeds a tmux session whose new-session PAYLOAD
# runs one of these scripts, e.g.
#   sh /opt/pocketshell-agent-fixtures/idle-incremental-claude.sh <MARKER> 40
#   sh /opt/pocketshell-agent-fixtures/busy-agent-burst.sh <MARKER> 40
#   * idle-incremental-claude.sh — paints a full TUI frame once, then repaints
#     only a spinner line in place (idle Claude that can never self-heal a lost
#     grid; recovery must come from the reconciler).
#   * busy-agent-burst.sh — saturates the `-CC` channel with heavy repaint bursts
#     (the #1297 capture-wedge state), alternating with a stable authoritative
#     banner so convergence stays assertable.
COPY tests/docker/agent-fixtures/ /opt/pocketshell-agent-fixtures/
COPY tests/docker/agent-entrypoint.sh /usr/local/bin/pocketshell-agent-entrypoint
COPY app/build.gradle.kts /opt/pocketshell-app-build.gradle.kts

RUN chmod 600 /home/testuser/.ssh/authorized_keys /root/test_key \
    && chmod +x /usr/local/bin/claude \
        /usr/local/bin/codex \
        /usr/local/bin/opencode \
        /usr/local/bin/pocketshell \
        /usr/local/bin/quse \
        /usr/local/bin/agent-log-explorer \
        /usr/local/bin/tmux \
        /usr/local/bin/tmuxctl \
        /usr/local/bin/uv \
        /usr/local/bin/systemctl \
        /usr/local/bin/pocketshell-tui-smoke \
        /usr/local/bin/pocketshell-fake-agent \
        /usr/local/bin/pocketshell-agent-entrypoint \
    && version="$(sed -n 's/^[[:space:]]*versionName[[:space:]]*=[[:space:]]*"\([^"]*\)".*$/\1/p' /opt/pocketshell-app-build.gradle.kts | head -n 1)" \
    && test -n "$version" \
    && printf '%s\n' "$version" > /opt/pocketshell-agent-fixture-version \
    && chown -R testuser:testuser /home/testuser/.ssh

EXPOSE 22

CMD ["/usr/local/bin/pocketshell-agent-entrypoint"]
