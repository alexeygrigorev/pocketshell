<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Required for the Phase 0 proof-of-life screen to open an SSH
        connection to the configured host. Phase 1 will revisit this when
        the host management UI lands — for now this single permission
        covers the smoke test.

        INTERNET is also required by the voice prompt composer (issue #15)
        for the multipart upload to OpenAI's Whisper endpoint.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Issue #15: the prompt composer captures microphone audio for the
        Whisper transcription round-trip. `RECORD_AUDIO` is declared at
        manifest level (system-level gating) and additionally requested at
        runtime — see `PromptComposerSheet` for the runtime prompt flow
        via `rememberLauncherForActivityResult`.
    -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PocketShell">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PocketShell">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".terminal.TerminalLabActivity"
            android:exported="false"
            android:theme="@style/Theme.PocketShell" />

        <receiver
            android:name=".systemsurfaces.ActiveSessionsWidgetProvider"
            android:exported="true"
            android:label="@string/widget_active_sessions_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/active_sessions_widget_info" />
        </receiver>

        <service
            android:name=".systemsurfaces.ForwardingTileService"
            android:exported="true"
            android:icon="@drawable/ic_qs_forwarding"
            android:label="@string/qs_forwarding_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name=".systemsurfaces.BootCompletedReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
