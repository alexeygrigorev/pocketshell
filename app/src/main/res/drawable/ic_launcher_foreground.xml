<?xml version="1.0" encoding="utf-8"?>
<!--
    PocketShell launcher foreground for issue #612.

    The maintainer selected icon direction D plus Brand Board Direction 1
    ("Pocket Terminal"). This redraws that direction as clean vector
    geometry instead of embedding the generated contact-sheet raster:
    a pocket-sized terminal frame with a bold prompt chevron and cursor.

    Adaptive-icon canvas is 108x108. The OEM mask crops/scales aggressively,
    and Pixel Launcher folder previews add another circular crop, so all
    artwork is kept inside a conservative inner 48x50 zone (viewport coords
    30..78 on X, 30..80 on Y). Strokes are bold enough to render at mdpi
    (48px) without melting.

    Source design references:
    - https://github.com/alexeygrigorev/pocketshell/releases/download/feedback-assets/pocketshell-icon-contact-sheet-20260607.png
    - https://github.com/alexeygrigorev/pocketshell/releases/download/feedback-assets/pocketshell-brand-board-20260607.png
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Pocket terminal frame. Thick stroke keeps the silhouette at mdpi. -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#22D3EE"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M35,32 L73,32 Q76,32 76,35 L76,75 Q76,78 73,78 L35,78 Q32,78 32,75 L32,35 Q32,32 35,32 Z" />

    <!-- Terminal title bar / pocket lip. -->
    <path
        android:fillColor="#22D3EE"
        android:pathData="M34,41 L74,41 L74,46 L34,46 Z" />

    <!-- Prompt chevron. Filled polygons avoid thin strokes after masking. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M37,54 L41.5,50.5 L57,64 L52.5,67.5 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M41.5,77.5 L37,74 L52.5,60.5 L57,64 Z" />

    <!-- Cursor block. -->
    <path
        android:fillColor="#22D3EE"
        android:pathData="M60,71 L71,71 L71,77 L60,77 Z" />

    <!-- Small pocket notch echoing the D crop's vertical terminal detail. -->
    <path
        android:fillColor="#22D3EE"
        android:pathData="M70,54 L74,54 L74,66 L70,66 Z" />
</vector>
