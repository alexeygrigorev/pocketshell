<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon (API 26+). PocketShell's minSdk is 26
    (see app/build.gradle.kts), so this single adaptive entry covers
    every supported device — no pre-26 PNG fallbacks shipped.
    See app/src/main/res/ICON_NOTES.md for the rationale.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
