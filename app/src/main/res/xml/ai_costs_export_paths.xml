<?xml version="1.0" encoding="utf-8"?>
<!--
    Paths exposed by the `.fileprovider` authority for `ACTION_SEND` /
    clipboard content URIs. Scoped to the specific cache subdirectories
    that produce shareable files so the authority can't accidentally
    expose anything else from the app's cache:

    - `ai-costs-export/` (issue #181): the "Export as CSV" affordance on
      the AI Costs screen writes a timestamped file there and hands its
      content URI to `ACTION_SEND`.
    - `file-viewer/` (issue #559): the in-app file viewer caches the
      downloaded preview file there. Share / Copy on the viewer hand that
      cached file's content URI to `ACTION_SEND` / the clipboard so the
      opened image / PDF / audio / text can be sent on to another app.
      Must match `FileViewerViewModel.CACHE_SUBDIR`.
    - `report-archives/` (issue #575): the crash reports screen zips
      local reports there before handing the bundle to Android's share
      sheet.
    - `diagnostics-export/` (issue #549): Settings -> Diagnostics copies
      the current connection/action event log there for ACTION_SEND.
-->
<paths>
    <cache-path
        name="ai-costs-export"
        path="ai-costs-export/" />
    <cache-path
        name="file-viewer"
        path="file-viewer/" />
    <cache-path
        name="report-archives"
        path="report-archives/" />
    <cache-path
        name="diagnostics-export"
        path="diagnostics-export/" />
</paths>
