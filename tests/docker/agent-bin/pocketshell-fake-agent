#!/usr/bin/env bash
# Issue #869: a MINIMAL, deterministic "fake agent" input box for the connected
# submit-journey proof. The real `claude` / `codex` TUIs are unauthenticated in
# the sandbox (they wedge on a sign-in / connectivity screen and never render an
# input box), and the plain `agents` fixture shell does not present an agent
# input line that echoes typed-but-not-yet-submitted text. Without such a pane
# the #869 ack-gate's load-bearing property â€” does the `capture-pane` needle
# actually match a REAL agent input-box echo, especially a WRAPPED/reflowed long
# prompt? â€” cannot be proven on-device. This fixture closes that gap.
#
# Behaviour (intentionally tiny + deterministic):
#   * Presents a single visible input line: `> <typed-text>`. As the user types
#     (tmux `send-keys -l` literal chars from the composer Send), the characters
#     are ECHOED into that line so `capture-pane -p` shows the typed-but-not-yet-
#     submitted payload â€” exactly what the #869 ack-gate polls for.
#   * The line WRAPS/REFLOWS naturally: when the buffer exceeds the pane width
#     the terminal wraps it across visible rows, so `capture-pane` returns the
#     payload split across rows. This is the most likely real-world needle MISS
#     (a substring spanning a wrap boundary), so the proof MUST exercise it.
#   * A SINGLE-LINE bracketed paste (`\e[200~` ... `\e[201~` with no embedded
#     newline) is shown as plain text, like a readline agent input box, not the
#     literal escape sequence.
#   * Issue #1687 â€” a MULTI-LINE bracketed paste is COLLAPSED to a Claude-Code
#     placeholder chip `[Pasted text #N +M lines]` and the body is NOT echoed,
#     EXACTLY as the real `claude` TUI does (verified against the shipped Claude
#     Code 2.1.150 binary: `jgH(H,$){...return`[Pasted text #${H} +${$} lines]`}`,
#     `#N` a session-relative paste counter, `+M` the extra-line count). This is
#     the case the #1687 ack-gate fix hinges on: the payload-tail needle can
#     NEVER match a collapsed paste (the body is not on the pane), so before the
#     fix the ack polled to its full timeout + fallback floor on EVERY multi-line
#     send â€” the maintainer's "takes too long to send even when the connection is
#     okay". The pane now reproduces that exact chip so the connected journey can
#     prove the ack recognises it (the collapsed-marker count-baseline) and fires
#     the submit Enter WITHOUT the stall. The real (multi-line) body is retained
#     internally so the submit still lands the real content.
#   * On Enter (`\r` / `\n`) it SUBMITS: prints a `FAKE-AGENT SUBMITTED: <text>`
#     line into the scrollback and clears the input box. The connected test
#     asserts this submitted marker appears AND the input box is left empty â€”
#     proving the composer Send actually submitted the line (the maintainer's
#     "when I click Send it's not really sending" symptom), not left it unsent.
#
# It deliberately does NOT use the alternate screen (no smcup): keeping the
# transcript in the main buffer means `capture-pane -p` reads the input box and
# the submitted markers directly, which is what the ack-gate + the test inspect.
set -u

PROMPT_PREFIX="> "
SUBMIT_PREFIX="FAKE-AGENT SUBMITTED: "
READY_MARKER="FAKE-AGENT-READY"

old_tty="$(stty -g 2>/dev/null || true)"

cleanup() {
  if [ -n "${old_tty:-}" ]; then
    stty "$old_tty" 2>/dev/null || true
  else
    stty sane 2>/dev/null || true
  fi
  printf '\033[?25h'
  printf '\r\nFAKE-AGENT-EXIT\r\n'
  exit 0
}
trap cleanup INT TERM

# Raw, no-echo: we draw the input box ourselves so the echo is deterministic.
stty -echo -icanon -icrnl min 1 time 0 2>/dev/null || true

# `buffer` is what the input box DISPLAYS (`> <buffer>`). For normal typing and a
# single-line paste it equals the entered text. For a #1687 collapsed multi-line
# paste it holds the `[Pasted text #N +M lines]` chip. `submit_buffer` is what a
# submit Enter actually sends â€” always the REAL entered/pasted content, so a
# collapsed paste still submits its real multi-line body.
buffer=""
submit_buffer=""
last_submitted=""
# Issue #1687: session-relative paste counter, mirroring Claude Code's `#N`.
paste_counter=0

# Redraw the whole viewport cleanly: home + clear screen, print the readiness
# marker, the most-recent submitted line (if any), then the input box. Clearing
# the whole screen each render keeps the reflowed input box artifact-free as the
# buffer wraps (a partial `\033[J` leaves stale wrapped rows above the cursor).
# The terminal wraps the buffer when it exceeds the pane width, producing the
# reflowed input box the #869 needle must survive.
render() {
  printf '\033[H\033[2J'
  printf '%s\r\n' "$READY_MARKER"
  if [ -n "$last_submitted" ]; then
    printf '%s%s\r\n' "$SUBMIT_PREFIX" "$last_submitted"
  fi
  printf '%s%s' "$PROMPT_PREFIX" "$buffer"
}

render

# Bash ANSI-C quoting ($'...') preserves the control byte EXACTLY. Command
# substitution `$(printf '\r')` would strip the trailing CR, leaving an empty
# string â€” so the CR/submit case would never match.
CR=$'\r'
LF=$'\n'
DEL=$'\177'
BS=$'\b'
CU=$'\025'
ESC=$'\033'

# Read ONE byte. Returns it in REPLY (empty for a NUL / EOF). Uses bash `read`
# rather than a per-byte `dd` so a long pasted prompt (hundreds of chars) is
# ingested fast enough for `capture-pane` to see it within the ack-gate window.
read_byte() {
  IFS= read -r -s -N 1 REPLY
}

# Issue #1687: read a bracketed-paste body until the `\e[201~` end marker. The
# body may arrive across several `send-keys -H` chunks (the composer chunks the
# paste by BODY_CHUNK_BYTES), so this blocks until the end marker â€” which the
# composer always writes. Returns the body in PASTE_BODY and whether it spanned
# more than one line in PASTE_HAD_LF (a `\n`/`\r` inside the paste is CONTENT
# here, NOT a submit â€” a multi-line paste is one paste, not many submits).
read_paste_body() {
  PASTE_BODY=""
  PASTE_HAD_LF=0
  while true; do
    read_byte || cleanup
    b="$REPLY"
    if [ "$b" = "$ESC" ]; then
      read_byte || cleanup
      if [ "$REPLY" = "[" ]; then
        csi=""
        while true; do
          read_byte || cleanup
          case "$REPLY" in
            [@A-Za-z~]) fin="$REPLY"; break ;;
            *) csi="$csi$REPLY" ;;
          esac
        done
        # `201~` closes the paste; any other CSI inside the body is ignored.
        if [ "$fin" = "~" ] && [ "$csi" = "201" ]; then return 0; fi
        continue
      fi
      continue
    fi
    case "$b" in
      "$CR"|"$LF") PASTE_HAD_LF=1; PASTE_BODY="$PASTE_BODY$LF" ;;
      "") : ;;
      *) PASTE_BODY="$PASTE_BODY$b" ;;
    esac
  done
}

# Consume a CSI escape sequence. A bracketed-paste START (`\e[200~`) reads the
# whole paste body (see read_paste_body) and then either:
#   * COLLAPSES a MULTI-LINE paste to the Claude-Code `[Pasted text #N +M lines]`
#     chip in the DISPLAY buffer while keeping the real body for submit (#1687), or
#   * echoes a SINGLE-LINE paste inline (the pre-#1687 readline-box behaviour the
#     #869 / #1526 journeys rely on).
# Any other CSI (bracketed-paste markers aside â€” cursor keys etc.) is ignored,
# same as before.
handle_esc() {
  read_byte || cleanup
  [ "$REPLY" = "[" ] || return 0
  local csi="" fin=""
  while true; do
    read_byte || cleanup
    case "$REPLY" in
      [@A-Za-z~]) fin="$REPLY"; break ;;
      *) csi="$csi$REPLY" ;;
    esac
  done
  if [ "$fin" = "~" ] && [ "$csi" = "200" ]; then
    read_paste_body
    if [ "$PASTE_HAD_LF" = "1" ]; then
      # Extra-line count = number of newlines, matching Claude Code's `+M`.
      extra=$(printf '%s' "$PASTE_BODY" | tr -cd "$LF" | wc -c | tr -d ' ')
      paste_counter=$((paste_counter + 1))
      buffer="$buffer[Pasted text #$paste_counter +$extra lines]"
      submit_buffer="$submit_buffer$PASTE_BODY"
    else
      buffer="$buffer$PASTE_BODY"
      submit_buffer="$submit_buffer$PASTE_BODY"
    fi
    dirty=1
  fi
}

# Handle one input byte. Shared by the initial read and the debounce drain so a
# paste is parsed identically no matter which loop sees its leading ESC.
process_byte() {
  ch="$1"
  [ -z "$ch" ] && return 0
  case "$ch" in
    "$CR"|"$LF")
      # Submit: record the submitted line (shown by the next render) and clear
      # the input box, so `capture-pane` shows the SUBMITTED marker AND an empty
      # input â€” proving the composer Send actually submitted the line. The
      # submitted text is the REAL content (submit_buffer), so a #1687 collapsed
      # paste still lands its real multi-line body.
      last_submitted="$submit_buffer"
      buffer=""
      submit_buffer=""
      dirty=1
      ;;
    "$DEL"|"$BS")
      buffer="${buffer%?}"
      submit_buffer="${submit_buffer%?}"
      dirty=1
      ;;
    "$CU")
      # Ctrl-U: clear the whole input line (readline kill-line). Lets a test
      # reset the input box between cases deterministically.
      buffer=""
      submit_buffer=""
      dirty=1
      ;;
    "$ESC")
      handle_esc
      ;;
    *)
      buffer="$buffer$ch"
      submit_buffer="$submit_buffer$ch"
      dirty=1
      ;;
  esac
}

# Render is debounced: after each byte we keep reading any IMMEDIATELY-available
# bytes (a burst from `send-keys -l` arrives back-to-back) and only redraw once
# the burst drains, so a 300-char paste renders once, not 300 times.
dirty=0
flush() {
  if [ "$dirty" = "1" ]; then
    render
    dirty=0
  fi
}

while true; do
  if ! read_byte; then
    # EOF on the channel â€” exit; the outer `exec sh` keeps the pane alive.
    cleanup
  fi
  process_byte "$REPLY"
  # Drain any back-to-back burst bytes before redrawing (debounce).
  while IFS= read -r -s -N 1 -t 0.02 REPLY; do
    process_byte "$REPLY"
  done
  flush
done
